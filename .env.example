# Local safe mode: no Telegram delivery and no state changes.
DRY_RUN=true

# GitHub Models is optional. Do not put GITHUB_TOKEN in this file.
AI_ENABLED=false
AI_PROVIDER=fake
AI_MODEL=openai/gpt-4o
AI_BATCH_SIZE=5
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=2
AI_FILTER_ENABLED=false
AI_MIN_IMPORTANCE=low
